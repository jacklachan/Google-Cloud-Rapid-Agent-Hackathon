# ---------------------------------------------------------------------------
# Faultline env contract. Copy to `.env` and fill in. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- Google Cloud -----------------------------------------------------------
# GCP project hosting Vertex AI + Cloud Logging/Trace/Monitoring + Cloud Run.
GOOGLE_CLOUD_PROJECT=

# Region for Vertex AI + Cloud Run. Common: us-central1, us-east1, europe-west1.
GOOGLE_CLOUD_REGION=us-central1

# Tells google-genai / google-adk to talk to Vertex AI (NOT the public AI Studio).
GOOGLE_GENAI_USE_VERTEXAI=true

# Gemini model id on Vertex AI. Final value confirmed in phase 4 from live docs.
# Leave blank now; phase-4 code will fail loud if unset so we cannot ship wrong.
VERTEX_AI_MODEL=

# --- GitLab MCP -------------------------------------------------------------
# GitLab instance. Use https://gitlab.com for SaaS or your self-hosted URL.
GITLAB_URL=https://gitlab.com

# Full project path, e.g. "mohit/faultline-victim".
GITLAB_PROJECT_PATH=

# Personal access token. Required scopes: api, read_repository, write_repository.
# Create at: <GITLAB_URL>/-/user_settings/personal_access_tokens
GITLAB_TOKEN=

# How to launch the GitLab MCP server locally. Filled in phase 3 once we pick
# the canonical implementation (npx / docker / binary). Example placeholder:
GITLAB_MCP_COMMAND=

# --- Victim service ---------------------------------------------------------
# Public URL of the deployed victim frontend (Cloud Run service URL).
VICTIM_SERVICE_URL=

# --- Faultline runtime ------------------------------------------------------
# In fake mode the telemetry tools return canned data so pytest + local dev
# work with zero GCP calls. Set to 0 only when running a real investigation.
FAULTLINE_FAKE_TELEMETRY=1
